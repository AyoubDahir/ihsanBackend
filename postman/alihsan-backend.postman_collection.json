{
  "info": {
    "_postman_id": "de9d5e3b-a9d0-46ac-9ed4-7e5f553f779d",
    "name": "Alihsan Java Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.alihsans.com" },
    { "key": "patientId", "value": "PAT-0001" },
    { "key": "practitionerId", "value": "DOC-0001" },
    { "key": "mobile", "value": "252612221335" },
    { "key": "otp", "value": "" },
    { "key": "referenceId", "value": "" },
    { "key": "invoiceReferenceId", "value": "" },
    { "key": "invoiceId", "value": "" },
    { "key": "phoneNumber", "value": "252612221335" }
  ],
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "2. Auth - Check Mobile",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/api/mobile/auth/check-mobile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "mobile", "auth", "check-mobile"]
        }
      }
    },
    {
      "name": "3. Auth - Send OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/api/mobile/auth/send-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "mobile", "auth", "send-otp"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "if (j && j.otp) { pm.collectionVariables.set('otp', j.otp); }"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Auth - Verify OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": \"{{otp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/mobile/auth/verify-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "mobile", "auth", "verify-otp"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "if (j && j.patientId) { pm.collectionVariables.set('patientId', j.patientId); }"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Practitioners (Doctor + Price)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/practitioners",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "practitioners"]
        }
      }
    },
    {
      "name": "6. Create Appointment (Existing Patient)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"appointmentDate\": \"2026-03-20\",\n  \"appointmentTime\": \"10:30:00\",\n  \"department\": \"General Medicine\",\n  \"amount\": 5.00,\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"paymentType\": \"EVC\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "appointments"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function(){ pm.response.to.have.status(200); });",
              "const j = pm.response.json();",
              "pm.collectionVariables.set('referenceId', j.referenceId || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Create Appointment (Self Registration - Age Mandatory)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Ali\",\n  \"mobile\": \"{{phoneNumber}}\",\n  \"sex\": \"Male\",\n  \"age\": 25,\n  \"ageType\": \"Year\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"appointmentDate\": \"2026-03-21\",\n  \"appointmentTime\": \"11:00:00\",\n  \"department\": \"General Medicine\",\n  \"amount\": 5.00,\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"paymentType\": \"EVC\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "appointments"]
        }
      }
    },
    {
      "name": "8. Payment Verify by Reference",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/payment/verify/{{referenceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payment", "verify", "{{referenceId}}"]
        }
      }
    },
    {
      "name": "9. Webhook (Approve Appointment Payment)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"referenceId\": \"{{referenceId}}\",\n  \"status\": \"APPROVED\",\n  \"providerTxnId\": \"WAAFI-TXN-APPT-001\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/payment/webhook",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payment", "webhook"]
        }
      }
    },
    {
      "name": "10. Patient Appointments",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/appointments?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "appointments"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      }
    },
    {
      "name": "11. Patient Lab Reports",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/lab-reports?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "lab-reports"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      }
    },
    {
      "name": "12. Billing - List Unpaid Invoices",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/billing/invoices?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "billing", "invoices"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "if (Array.isArray(j) && j.length > 0) {",
              "  pm.collectionVariables.set('invoiceId', j[0].invoiceId || j[0].name || '');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "13. Billing - Get One Unpaid Invoice",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/billing/invoices/{{invoiceId}}?patientId={{patientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "billing", "invoices", "{{invoiceId}}"],
          "query": [{ "key": "patientId", "value": "{{patientId}}" }]
        }
      }
    },
    {
      "name": "14. Billing - Start Invoice Payment",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"invoiceId\": \"{{invoiceId}}\",\n  \"amount\": 5.00,\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"paymentType\": \"EVC\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/billing/pay",
          "host": ["{{baseUrl}}"],
          "path": ["api", "billing", "pay"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.collectionVariables.set('invoiceReferenceId', j.referenceId || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "15. Webhook (Approve Invoice Payment)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"referenceId\": \"{{invoiceReferenceId}}\",\n  \"status\": \"APPROVED\",\n  \"providerTxnId\": \"WAAFI-TXN-INV-001\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/payment/webhook",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payment", "webhook"]
        }
      }
    },
    {
      "name": "16. Billing - Get Invoice Payment Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/billing/payments/{{invoiceReferenceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "billing", "payments", "{{invoiceReferenceId}}"]
        }
      }
    },
    {
      "name": "17. Negative Test - Missing Age on Self Registration",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Ali\",\n  \"mobile\": \"{{phoneNumber}}\",\n  \"sex\": \"Male\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"appointmentDate\": \"2026-03-21\",\n  \"appointmentTime\": \"11:00:00\",\n  \"department\": \"General Medicine\",\n  \"amount\": 5.00,\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"paymentType\": \"EVC\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/healthcare/appointments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "healthcare", "appointments"]
        }
      }
    }
  ]
}
