          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"firstName\": \"Jaabir\",\n  \"lastName\": \"Dahir\",\n  \"fullName\": \"Jaabir Dahir\",\n  \"mobile\": \"{{mobile}}\",\n  \"sex\": \"Male\",\n  \"age\": 28,\n  \"ageType\": \"Year\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"appointmentDate\": \"{{appointmentDate}}\",\n  \"appointmentTime\": \"{{appointmentTime}}\",\n  \"department\": \"{{department}}\",\n  \"amount\": 1.1,\n  \"phoneNumber\": \"{{mobile}}\",\n  \"paymentType\": \"EVC\"\n}"
        }
