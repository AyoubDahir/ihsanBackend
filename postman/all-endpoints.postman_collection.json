  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth Check Mobile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/mobile/auth/check-mobile",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"{{mobile}}\"\n}"
        }
      }
    },
    {
      "name": "Auth Self Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/mobile/auth/self-register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Jaabir\",\n  \"lastName\": \"Dahir\",\n  \"fullName\": \"Jaabir Dahir\",\n  \"mobile\": \"{{mobile}}\",\n  \"sex\": \"Male\",\n  \"age\": 28,\n  \"ageType\": \"Year\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j && j.patientId) pm.collectionVariables.set('patientId', j.patientId);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/mobile/auth/send-otp",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"{{mobile}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j && j.otp) pm.collectionVariables.set('otp', j.otp);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/mobile/auth/verify-otp",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": \"{{otp}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (j && j.patientId) pm.collectionVariables.set('patientId', j.patientId);"
            ]
          }
        }
      ]
    },
    {
